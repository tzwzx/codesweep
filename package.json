{
  "name": "@tzwzx/codesweep",
  "version": "1.1.4",
  "description": "Run code quality checks in one command 🧹",
  "keywords": [
    "cli",
    "code-quality",
    "formatter",
    "linter",
    "orchestrator",
    "test-runner",
    "typecheck"
  ],
  "homepage": "https://github.com/tzwzx/codesweep#readme",
  "bugs": {
    "url": "https://github.com/tzwzx/codesweep/issues"
  },
  "license": "MIT",
  "author": "tzwzx",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tzwzx/codesweep.git"
  },
  "bin": {
    "codesweep": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "oxfmt --check && oxlint",
    "fix": "oxfmt && oxlint --fix",
    "tsc": "tsc --noEmit",
    "spellcheck": "cspell",
    "spellcheck:unused": "cspell-check-unused-words",
    "syncpack": "syncpack lint",
    "test": "bun test",
    "codesweep:check": "node dist/cli.js check",
    "codesweep:fix": "node dist/cli.js fix",
    "prepublishOnly": "bun run build",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "concurrently": "10.0.3",
    "yaml": "2.9.0"
  },
  "devDependencies": {
    "@types/node": "26.1.1",
    "bun-types": "1.3.14",
    "cspell": "10.0.1",
    "cspell-check-unused-words": "1.6.3",
    "fallow": "3.3.0",
    "lefthook": "2.1.10",
    "oxfmt": "0.58.0",
    "oxlint": "1.73.0",
    "syncpack": "15.3.2",
    "typescript": "7.0.2",
    "ultracite": "7.9.3"
  },
  "engines": {
    "bun": ">=1",
    "node": ">=22"
  }
}
